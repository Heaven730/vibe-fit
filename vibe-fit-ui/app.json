{
  "expo": {
    "name": "Vibe Fit",
    "slug": "vibe-fit",
    "version": "1.0.0",
    "icon": "./assets/logo/logo.png",
    "orientation": "portrait",
    "scheme": "vibefit",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.fronend"
    },
    "android": {
      "package": "com.vibefit.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
